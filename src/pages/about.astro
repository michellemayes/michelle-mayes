---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import aboutPhoto from '../../public/about-photo.jpg';

// Prerender this page as static
export const prerender = true;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About - ${SITE_TITLE}`} description="Full-stack builder at the intersection of AI and product development, based in Austin, TX." />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="section-header">
				<h1>About Me</h1>
			</div>

			<div class="about-card">
				<div class="about-card-header">
					<Image src={aboutPhoto} alt="Michelle Mayes" class="about-photo" width={120} height={120} loading="lazy" />
					<div class="about-info">
						<p>
							I build practical products at the intersection of AI and web development, with a strong bias toward shipping quickly and learning in public.
						</p>
						<p>
							My background spans Data Science, Policy, and AdTech, and I bring that product perspective into modern full-stack work: clear problem framing, fast iteration, and outcome-focused decisions.
						</p>
						<p>
							Right now I am focused on opportunities where I can build with high-velocity teams, improve developer workflows with AI, and share what works through writing and talks.
						</p>
						<p>
							Based in Austin, TX.
						</p>
					</div>
				</div>
			</div>

			<div class="github-activity-section">
				<h3>My GitHub Activity</h3>
				<div class="github-calendar-container">
					<img
						src="https://ghchart.rshah.org/michellemayes"
						alt="Michelle Mayes GitHub Activity"
						class="github-calendar"
						loading="lazy"
						decoding="async"
						referrerpolicy="no-referrer"
					/>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-xl);
	}

	.section-header {
		text-align: center;
		margin-bottom: var(--space-2xl);
	}

	.section-header h1 {
		font-size: var(--text-fluid-4xl);
		margin-bottom: var(--space-md);
		color: var(--accent);
	}

	.section-header p {
		font-size: var(--text-lg);
		color: var(--text-muted);
		max-width: 500px;
		margin: 0 auto;
	}

	.about-card {
		max-width: 800px;
		margin: 0 auto var(--space-2xl) auto;
		background: var(--bg-card);
		border: 1px solid var(--accent-100);
		border-radius: var(--radius-xl);
		padding: var(--space-xl);
		box-shadow: var(--shadow-lg);
	}

	.about-card-header {
		display: flex;
		align-items: flex-start;
		gap: var(--space-lg);
	}

	.about-photo {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
		border: 3px solid var(--accent);
		flex-shrink: 0;
	}

	.about-info {
		flex: 1;
	}

	.about-info h2 {
		margin: 0 0 var(--space-md) 0;
		font-size: var(--text-fluid-2xl);
		color: var(--text);
	}

	.about-info p {
		margin-bottom: var(--space-md);
		color: var(--text-muted);
		line-height: var(--leading-relaxed);
	}

	.about-info p:last-child {
		margin-bottom: 0;
	}

	.github-activity-section {
		margin: var(--space-2xl) 0;
		text-align: center;
	}

	.github-activity-section h3 {
		font-size: var(--text-fluid-2xl);
		color: var(--warm);
		margin-bottom: var(--space-xl);
	}

	.github-calendar-container {
		background: var(--bg-card);
		border: 1px solid var(--accent-100);
		border-radius: var(--radius-lg);
		padding: var(--space-lg);
		box-shadow: var(--shadow-lg);
		display: inline-block;
	}

	.github-calendar {
		width: 100%;
		max-width: 800px;
		height: auto;
		border-radius: var(--radius-md);
	}

	@media (max-width: 768px) {
		main {
			padding: var(--space-md);
		}

		.section-header p {
			font-size: var(--text-base);
		}

		.about-card {
			padding: var(--space-lg);
		}

		.about-card-header {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: var(--space-md);
		}

		.about-photo {
			width: 100px;
			height: 100px;
			align-self: center;
		}

		.about-info h2 {
			font-size: var(--text-xl);
		}

		.about-info p {
			font-size: var(--text-sm);
		}

		.github-calendar-container {
			padding: var(--space-md);
		}

		.github-calendar {
			max-width: 100%;
		}
	}

	@media (max-width: 480px) {
		main {
			padding: var(--space-sm);
		}

		.about-card {
			padding: var(--space-md);
		}

		.about-photo {
			width: 80px;
			height: 80px;
			align-self: center;
		}

		.about-info h2 {
			font-size: var(--text-xl);
		}

		.about-info p {
			font-size: var(--text-sm);
		}

		.github-calendar-container {
			padding: var(--space-sm);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.about-card {
			transition: none;
		}
	}
</style>
