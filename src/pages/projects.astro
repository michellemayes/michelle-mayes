---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, GITHUB_USERNAME } from '../consts';
import { fetchRepositories } from '../lib/github';
import { bucketProjects, getProjectDescription } from '../lib/projects';

export const prerender = true;

const repositories = await fetchRepositories(GITHUB_USERNAME);
const { featured: featuredRepositories, catalog: catalogRepositories } = bucketProjects(repositories, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Projects - ${SITE_TITLE}`}
      description="Selected projects with impact-focused summaries, followed by the full GitHub catalog."
    />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <div class="section-header">
        <h1>Selected Work</h1>
        <p>
          Highlighted projects with the strongest impact, plus the full GitHub catalog.
        </p>
      </div>

      {featuredRepositories.length > 0 && (
        <section class="featured-section">
          <div class="section-heading">
            <h2>Featured Case Studies</h2>
            <p>Projects with the most traction and clearest outcomes.</p>
          </div>

          <div class="featured-grid">
            {featuredRepositories.map((repo) => (
              <article class="featured-card">
                <div class="featured-header">
                  <h3>
                    <a href={repo.html_url} target="_blank" rel="noopener noreferrer">{repo.name}</a>
                  </h3>
                  <span class="focus-chip">{repo.focusArea}</span>
                </div>

                <p class="featured-summary">
                  {getProjectDescription(repo.description)}
                </p>

                <p class="impact-line">{repo.impactSignal}</p>

                <div class="featured-meta">
                  <span>⭐ {repo.stargazers_count}</span>
                  <span>🍴 {repo.forks_count}</span>
                  <span>Updated {new Date(repo.updated_at).toLocaleDateString()}</span>
                </div>

                <a href={repo.html_url} class="project-link" target="_blank" rel="noopener noreferrer">
                  View on GitHub
                </a>
              </article>
            ))}
          </div>
        </section>
      )}

      {catalogRepositories.length > 0 && (
        <section class="catalog-section">
          <div class="section-heading">
            <h2>Project Catalog</h2>
            <p>All active repositories, sorted by recent updates.</p>
          </div>

          <div class="projects-grid">
            {catalogRepositories.map((repo) => (
              <article class="project-card-small">
                <div class="project-card-header">
                  <h3>
                    <a href={repo.html_url} target="_blank" rel="noopener noreferrer">{repo.name}</a>
                  </h3>
                  <div class="project-stats">
                    <span>⭐ {repo.stargazers_count}</span>
                    <span>🍴 {repo.forks_count}</span>
                  </div>
                </div>

                <div class="project-card-content">
                  <p class="project-description">
                    {getProjectDescription(repo.description)}
                  </p>

                  <div class="project-meta">
                    {repo.language && <span class="language-badge">{repo.language}</span>}
                    <span class="update-date">Updated {new Date(repo.updated_at).toLocaleDateString()}</span>
                  </div>
                </div>

                <div class="project-card-footer">
                  <a href={repo.html_url} class="project-link" target="_blank" rel="noopener noreferrer">
                    View on GitHub
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {repositories.length === 0 && (
        <div class="empty-state">
          <h3>Couldn't load projects</h3>
          <p>GitHub isn't responding right now. Check back shortly or <a href="https://github.com/michellemayes" target="_blank" rel="noopener">browse directly on GitHub</a>.</p>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-xl);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .section-header h1 {
    font-size: var(--text-fluid-4xl);
    margin-bottom: var(--space-sm);
    color: var(--accent);
  }

  .section-header p {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 680px;
    margin: 0 auto;
    line-height: var(--leading-normal);
  }

  .featured-section,
  .catalog-section {
    margin-bottom: var(--space-2xl);
  }

  .section-heading {
    margin-bottom: var(--space-md);
  }

  .section-heading h2 {
    font-size: var(--text-fluid-2xl);
    margin-bottom: var(--space-xs);
  }

  .section-heading p {
    color: var(--text-muted);
    margin: 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .featured-card {
    background: linear-gradient(135deg, var(--bg-card), var(--accent-50));
    border: 1px solid var(--accent-100);
    border-radius: var(--radius-xl);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    box-shadow: var(--shadow-sm);
  }

  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .featured-header h3 {
    margin: 0;
    font-size: var(--text-xl);
  }

  .featured-header a {
    color: var(--text);
    text-decoration: none;
  }

  .featured-header a:hover {
    color: var(--accent-dark);
  }

  .focus-chip {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--warm-dark);
    background: var(--warm-50);
    border-radius: var(--radius-full);
    padding: var(--space-xs) var(--space-sm);
    white-space: nowrap;
  }

  .featured-summary {
    margin: 0;
    color: var(--text);
    line-height: var(--leading-normal);
  }

  .impact-line {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .project-card-small {
    background: var(--bg-card);
    border: 1px solid var(--accent-100);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .project-card-small:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .project-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-sm);
    gap: var(--space-sm);
  }

  .project-card-small h3 {
    margin: 0;
    font-size: var(--text-base);
    flex: 1;
  }

  .project-card-small h3 a {
    color: var(--accent);
    text-decoration: none;
  }

  .project-card-small h3 a:hover {
    text-decoration: underline;
  }

  .project-stats {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .project-card-content {
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .project-description {
    margin: 0 0 var(--space-sm) 0;
    color: var(--text-muted);
    line-height: var(--leading-normal);
    font-size: var(--text-sm);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
  }

  .language-badge {
    background: var(--accent-100);
    color: var(--accent-dark);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .update-date {
    color: var(--text-muted);
  }

  .project-card-footer {
    margin-top: auto;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: max-content;
    min-height: 44px;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 700;
    background: var(--accent-50);
    color: var(--accent-dark);
    border: 1px solid var(--accent-200);
    text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .project-link:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--bg-card);
    border: 1px solid var(--accent-100);
    border-radius: var(--radius-lg);
  }

  .empty-state p {
    color: var(--text-muted);
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    main {
      padding: var(--space-md);
    }

    .section-header p {
      font-size: var(--text-base);
    }

    .project-link {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: var(--space-sm);
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .featured-card {
      padding: var(--space-md);
    }

    .section-heading p {
      font-size: var(--text-sm);
    }

    .project-card-small {
      padding: var(--space-md);
    }

    .empty-state {
      padding: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card-small {
      transition: none;
    }

    .project-card-small:hover {
      transform: none;
    }
  }
</style>
