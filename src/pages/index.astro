---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroStats from '../components/HeroStats.astro';
import Timeline from '../components/Timeline.astro';
import { SITE_DESCRIPTION, SITE_TITLE_FULL, SOCIAL_LINKS } from '../consts';
import { getHomeData } from '../lib/home-data';

export const prerender = true;

const { stats, timelineItems } = await getHomeData();

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Michelle Mayes",
	"url": "https://michellemayes.me",
	"jobTitle": "Full-Stack Builder & AI Product Engineer",
	"description": SITE_DESCRIPTION,
	"image": "https://michellemayes.me/avatar.jpg",
	"sameAs": [
		SOCIAL_LINKS.github,
		SOCIAL_LINKS.linkedin,
		SOCIAL_LINKS.twitter,
	],
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE_FULL} description={SITE_DESCRIPTION} jsonLd={personSchema} />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <HeroStats stats={stats} />

      <section class="timeline-section">
        <h2>What I've Shipped</h2>
        <Timeline items={timelineItems} />
      </section>

      <!-- Contact CTA -->
      <section class="contact-section">
        <div class="contact-card">
          <h2>Let's Build Something</h2>
          <p>Have a project in mind, or want to talk AI and product development? Let's make it happen.</p>
          <a href="https://calendar.app.google/yYSHV4KQ4zJsxkdt5" target="_blank" rel="noopener noreferrer" class="cta-button">
            <span>Schedule a Chat</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--space-xl);
  }

  .timeline-section {
    margin-top: var(--space-2xl);
  }

  .timeline-section h2 {
    font-family: var(--font-serif);
    font-size: var(--text-fluid-2xl);
    font-weight: 700;
    color: var(--text);
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    main {
      padding: var(--space-lg);
    }

  }

  @media (max-width: 480px) {
    main {
      padding: var(--space-md);
    }
  }

  /* Contact Section */
  .contact-section {
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) 0;
  }

  .contact-card {
    background: linear-gradient(135deg, var(--bg-card), var(--warm-50));
    border: 1px solid var(--warm-100);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }

  .contact-section h2 {
    font-family: var(--font-serif);
    font-size: var(--text-fluid-2xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .contact-section p {
    color: var(--text-muted);
    font-size: var(--text-lg);
    max-width: 500px;
    margin: 0 auto var(--space-xl) auto;
    line-height: var(--leading-relaxed);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--warm);
    color: white;
    padding: var(--space-md) var(--space-xl);
    border-radius: 12px;
    font-weight: 600;
    font-size: var(--text-lg);
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(217, 119, 6, 0.2);
    min-height: 44px;
  }

  .cta-button:hover {
    background: var(--warm-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(217, 119, 6, 0.3);
  }

  .cta-button:active {
    transform: scale(0.98);
  }

  .cta-button svg {
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .contact-card {
      padding: var(--space-xl) var(--space-lg);
    }

    .contact-section p {
      font-size: var(--text-base);
    }

    .cta-button {
      padding: var(--space-md) var(--space-lg);
      font-size: var(--text-base);
    }
  }

  @media (max-width: 480px) {
  }
</style>
